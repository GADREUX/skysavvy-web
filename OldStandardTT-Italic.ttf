"use client"
import Link from "next/link"
import { usePathname } from "next/navigation"

const NAV = [
  { id: "overview",  href: "/dashboard", label: "Overview" },
  { id: "watches",   href: "/route",     label: "Watches",   badge: 12 },
  { id: "calendar",  href: "/route",     label: "Calendar" },
  { id: "discovery", href: "/discovery",  label: "Discovery" },
  { id: "alerts",    href: "/alerts",     label: "Alerts",    badge: 3 },
  { id: "settings",  href: "/settings",   label: "Settings" },
]

export function Sidebar({ active }: { active: string }) {
  const pathname = usePathname()

  return (
    <aside style={{
      width: 220, background: "#fff", borderRight: "1px solid var(--line)",
      padding: "18px 12px", display: "flex", flexDirection: "column", gap: 4,
      minHeight: "100vh",
    }}>
      {/* Logo */}
      <div style={{ display: "flex", alignItems: "center", gap: 10, padding: "4px 10px 18px" }}>
        <div style={{
          width: 28, height: 28, borderRadius: "50%",
          background: "linear-gradient(135deg, #0f766e, #115e59)",
        }} />
        <div style={{ fontWeight: 900, letterSpacing: "-0.01em", fontSize: 18, fontFamily: "var(--font-sans)" }}>
          skysavvy
        </div>
      </div>

      {/* Nav */}
      {NAV.map((it) => (
        <Link key={it.id} href={it.href} style={{
          display: "flex", alignItems: "center", justifyContent: "space-between",
          padding: "9px 12px", borderRadius: 8,
          fontFamily: "var(--font-sans)", fontWeight: 700, fontSize: 14,
          color: active === it.id ? "var(--accent-strong)" : "var(--ink-2)",
          background: active === it.id ? "var(--accent-tint)" : "transparent",
          border: `1px solid ${active === it.id ? "var(--accent-soft)" : "transparent"}`,
          textDecoration: "none",
          transition: "background var(--t-fast) var(--ease)",
        }}>
          {it.label}
          {it.badge && (
            <span style={{
              background: active === it.id ? "var(--accent)" : "var(--line)",
              color: active === it.id ? "#fff" : "var(--muted)",
              fontSize: 10, fontWeight: 800, padding: "2px 7px", borderRadius: 999,
            }}>
              {it.badge}
            </span>
          )}
        </Link>
      ))}

      {/* Pro badge */}
      <div style={{
        marginTop: "auto", padding: 12,
        background: "var(--field-warm)", border: "1px solid #ecdfca",
        borderRadius: 8, fontSize: 12, fontFamily: "var(--font-serif)",
      }}>
        <div style={{ fontWeight: 800, color: "var(--warn)", fontFamily: "var(--font-sans)", fontSize: 11, textTransform: "uppercase", letterSpacing: "0.08em" }}>
          You're on Pro
        </div>
        <div style={{ color: "var(--warn-cream-ink)", marginTop: 3 }}>
          Unlimited watches · trending data · early-bird alerts.
        </div>
      </div>
    </aside>
  )
}
